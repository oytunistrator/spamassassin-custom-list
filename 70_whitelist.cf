# ---------------------------------------------------------------------------
# Whitelist authentication-based senders (SPF/DKIM/DMARC)
# ---------------------------------------------------------------------------
whitelist_auth  *@google.com
whitelist_auth  *@microsoft.com
whitelist_auth  *@apple.com
whitelist_auth  *@amazon.com
whitelist_auth  *@paypal.com

# ---------------------------------------------------------------------------
# URI whitelist - trusted domains found in message bodies
# ---------------------------------------------------------------------------
whitelist_uri_host  turkiye.gov.tr
whitelist_uri_host  gib.gov.tr
whitelist_uri_host  sgk.gov.tr
whitelist_uri_host  meb.gov.tr
whitelist_uri_host  ziraatbank.com.tr
whitelist_uri_host  garantibbva.com.tr
whitelist_uri_host  akbank.com
whitelist_uri_host  isbank.com.tr
whitelist_uri_host  google.com
whitelist_uri_host  microsoft.com
whitelist_uri_host  apple.com
whitelist_uri_host  amazon.com
whitelist_uri_host  paypal.com
whitelist_uri_host  github.com
whitelist_uri_host  linkedin.com

# ---------------------------------------------------------------------------
# Address list include (for local additions)
# ---------------------------------------------------------------------------
include lists/whitelisted_senders.txt
include lists/whitelisted_domains.txt
